# Google Drive shared folder URL (paste the link from Drive's "Copy link" button)
GOOGLE_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/your_folder_id_here?usp=sharing

# Google API Key (ต้องเปิด Google Drive API + Google Sheets API)
GOOGLE_API_KEY=your_google_api_key_here

# Vercel Cron secret (generate with: openssl rand -hex 32)
CRON_SECRET=your_cron_secret_here
